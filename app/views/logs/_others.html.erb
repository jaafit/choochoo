<%# A visible count that reveals the names on click. locals: names, suffix %>
<% if names.any? %>
  <details class="dropdown dropdown-end inline-block align-middle">
    <summary class="btn btn-xs btn-outline"><%= names.size %> <%= suffix %></summary>
    <ul class="dropdown-content menu bg-base-200 rounded-box shadow z-[1] w-44 p-2 mt-1 text-left">
      <% names.each do |n| %>
        <li><span><%= n %></span></li>
      <% end %>
    </ul>
  </details>
<% else %>
  <span class="badge badge-sm badge-ghost align-middle"><%= names.size %> <%= suffix %></span>
<% end %>
