<% content_for :title, "Log" %>

<section class="mt-2 mb-6 text-center">
  <h2 class="text-3xl font-bold">Log</h2>
  <%= link_to "← Back", app_root_path, class: "btn btn-ghost btn-sm mt-2" %>
</section>

<section class="max-w-xl mx-auto">
  <% if @logs.empty? %>
    <p class="text-center opacity-70">No changes yet.</p>
  <% else %>
    <%# Admins can undo the latest action here regardless of who did it — the only
        place that override lives. Limited to the single latest log (send-off). %>
    <% latest = @page == 1 ? @logs.first : nil %>
    <ul class="divide-y divide-base-300">
      <% @logs.each do |log| %>
        <li class="py-3 flex items-center gap-3">
          <span class="text-sm opacity-60 whitespace-nowrap w-28 shrink-0">
            <%= log.created_at.strftime("%b %-d, %Y") %>
          </span>
          <div class="text-left">
            <% case log.action %>
            <% when "nominate" %>
              <strong><%= log.actor_label %></strong> nominated <strong><%= log.player_name %></strong>
              <%# Everyone present but not nominated earns a ticket. %>
              <%= render "logs/others", names: [ log.player_name ] + log.other_names, suffix: "present",
                    notes: log.other_names.index_with { "+1 tix" } %>
            <% when "send_off" %>
              <strong><%= log.actor_label %></strong> started <strong><%= log.player_name %></strong>'s game
              <%# Each player sent earns +1; the chosen pays per player sent. %>
              <%= render "logs/others", names: [ log.player_name ] + log.other_names, suffix: "players",
                    notes: log.other_names.index_with { "+1 tix" }.merge(log.player_name => log.net_ticket_label) %>
            <% when "add" %>
              <strong><%= log.actor_label %></strong> added a ticket to <strong><%= log.player_name %></strong>
            <% when "subtract" %>
              <strong><%= log.actor_label %></strong> subtracted a ticket from <strong><%= log.player_name %></strong>
            <% when "add_player" %>
              <strong><%= log.actor_label %></strong> added <strong><%= log.player_name %></strong>
            <% when "delete" %>
              <strong><%= log.actor_label %></strong> deleted <strong><%= log.player_name %></strong>
            <% when "gift" %>
              <strong><%= log.actor_label %></strong> gave a ticket to <strong><%= log.player_name %></strong>
            <% when "promote" %>
              <strong><%= log.actor_label %></strong> promoted <strong><%= log.player_name %></strong> to admin
            <% when "demote" %>
              <strong><%= log.actor_label %></strong> demoted <strong><%= log.player_name %></strong>
            <% end %>
          </div>
          <% if current_admin? && log == latest && log.action == "send_off" %>
            <%= button_to "undo", app_undo_path, method: :post, class: "btn btn-xs btn-ghost ml-auto shrink-0",
                  params: { log_id: log.id, admin: true },
                  form: { data: { turbo_confirm: "Undo this send-off?" } } %>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="flex items-center justify-between mt-6">
      <% if @page > 1 %>
        <%= link_to "← Newer", app_logs_path(page: @page - 1), class: "btn btn-sm" %>
      <% else %>
        <span></span>
      <% end %>
      <span class="text-sm opacity-60">page <%= @page %></span>
      <% if @has_next %>
        <%= link_to "Older →", app_logs_path(page: @page + 1), class: "btn btn-sm" %>
      <% else %>
        <span></span>
      <% end %>
    </div>
  <% end %>
</section>
