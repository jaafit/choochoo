<% content_for :title, "Log" %>

<section class="mt-2 mb-6 text-center">
  <h2 class="text-3xl font-bold">Log</h2>
  <%= link_to "← Back", app_root_path, class: "btn btn-ghost btn-sm mt-2" %>
</section>

<section class="max-w-xl mx-auto">
  <% if @logs.empty? %>
    <p class="text-center opacity-70">No changes yet.</p>
  <% else %>
    <%# Admins can undo the latest action here, of any kind — the only place that
        override lives. Limited to the single latest log. The owner's own actions
        can only be undone by the owner. %>
    <% latest = @page == 1 ? @logs.first : nil %>
    <ul class="divide-y divide-base-300">
      <% @logs.each do |log| %>
        <li class="py-3 flex items-center gap-3">
          <span class="text-sm opacity-60 whitespace-nowrap w-28 shrink-0">
            <%= log.created_at.strftime("%b %-d, %Y") %>
          </span>
          <div class="text-left">
            <%= render "logs/entry", log: log %>
          </div>
          <% if current_admin? && log == latest %>
            <%# The owner's own actions can only be undone by the owner. %>
            <% if log.actor_player_id == @host.owner_id && current_player&.id != @host.owner_id %>
              <button type="button" class="btn btn-xs btn-ghost ml-auto shrink-0" disabled>undo</button>
            <% else %>
              <div class="ml-auto shrink-0" data-controller="confirm">
                <button type="button" class="btn btn-xs btn-ghost"
                        data-confirm-target="trigger" data-action="confirm#open">undo</button>
                <span class="hidden" data-confirm-target="prompt">
                  <%= form_with url: app_undo_path, method: :post, class: "inline-flex items-center gap-1" do |f| %>
                    <%= f.hidden_field :log_id, value: log.id %>
                    <%= f.button "confirm", type: "submit", class: "btn btn-xs btn-primary" %>
                    <button type="button" class="btn btn-xs btn-ghost" data-action="confirm#cancel">cancel</button>
                  <% end %>
                </span>
              </div>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="flex items-center justify-between mt-6">
      <% if @page > 1 %>
        <%= link_to "← Newer", app_logs_path(page: @page - 1), class: "btn btn-sm" %>
      <% else %>
        <span></span>
      <% end %>
      <span class="text-sm opacity-60">page <%= @page %></span>
      <% if @has_next %>
        <%= link_to "Older →", app_logs_path(page: @page + 1), class: "btn btn-sm" %>
      <% else %>
        <span></span>
      <% end %>
    </div>
  <% end %>
</section>
