<% content_for :title, "#{@host.display_name} | someonepick.com" %>
<%
  # Editing (admin) and gifting are server-rendered sub-flows focused on one
  # player by id. The raffle itself (present → pick → who's playing → send) lives
  # entirely in the browser via the `table` Stimulus controller; the server keeps
  # no round state, so several players can run a raffle at the same time.
  editing_player = current_admin? && params[:editing].present? ? @host.players.find_by(id: params[:editing]) : nil
  # Only the owner may edit the owner; other admins can't enter that edit view.
  editing_player = nil if editing_player && editing_player.id == @host.owner_id && editing_player.id != current_player&.id
  gift_recipient = params[:gifting].present? ? @host.players.find_by(id: params[:gifting]) : nil
  gifting        = !host_view? && gift_recipient && gift_recipient.id != current_player&.id

  # Admins can share a player's link except the owner's — unless it's their own.
  can_share = ->(player) { !(player.id == @host.owner_id && player.id != current_player&.id) }
%>

<% if current_admin? %>
  <%# Click the heading to rename the host; Escape cancels. %>
  <div class="text-center mb-10" data-controller="rename-host">
    <h1 class="text-4xl font-bold cursor-pointer inline-block" data-rename-host-target="display"
        data-action="click->rename-host#edit" title="Click to rename"><%= @host.display_name %></h1>
    <%= form_with url: app_host_path, method: :patch, scope: :host,
          class: "hidden", data: { rename_host_target: "form" } do |f| %>
      <%= f.text_field :name, value: @host.name, maxlength: 20, autocomplete: "off",
            placeholder: "Location name",
            class: "input input-bordered text-2xl font-bold text-center w-full max-w-md",
            data: { rename_host_target: "input", action: "keydown.esc->rename-host#cancel" } %>
    <% end %>
  </div>
<% else %>
  <h1 class="text-4xl font-bold text-center mb-10"><%= @host.display_name %></h1>
<% end %>

<% if host_view? %>
  <%# ---- Bootstrap: the host URL only mints the first admin (the owner). ----- %>
  <% if @host.players.empty? %>
    <section class="mt-8 text-center">
      <p class="text-xl mb-4">Add yourself to get started.</p>
      <%= form_with url: app_players_path, scope: :player, class: "flex flex-wrap items-center justify-center gap-3" do |f| %>
        <%= f.text_field :name, placeholder: "Your name", autocomplete: "off",
              autofocus: true, maxlength: 12, class: "input input-bordered" %>
        <%= f.submit "+", class: "btn btn-primary" %>
      <% end %>
    </section>
  <% else %>
    <%# Players exist but nobody is an admin yet: claim which one you are. %>
    <section class="mt-2 mb-6">
      <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
        <% @host.roster.each do |player| %>
          <%= button_to claim_host_player_path(@host, player), method: :patch,
                class: "block w-full p-0 bg-transparent border-0",
                form: { data: { turbo_confirm: "Confirm you are #{player.name}?" } } do %>
            <%= render "card", player: player, classes: "bg-base-100 shadow-md",
                  tickets_display: player.tickets, badge: nil %>
          <% end %>
        <% end %>
      </div>
    </section>
    <section class="text-center">
      <p class="text-2xl">Which player are you?</p>
    </section>
  <% end %>

<% elsif editing_player %>
  <%# ---- Admin edit controls for one focused player ----------------------- %>
  <% p = editing_player %>
  <section class="mt-2 mb-6">
    <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
      <% @host.roster.each do |player| %>
        <% focus = player.id == p.id %>
        <%= render "card", player: player,
              classes: (focus ? "bg-secondary text-secondary-content shadow-md" : "bg-base-100 shadow-md"),
              tickets_display: player.tickets, badge: (focus ? "editing" : nil),
              mine: (player.id == current_player&.id) %>
      <% end %>
    </div>
  </section>

  <section class="text-center">
    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
      <div class="justify-self-start">
        <% unless p.admin? %>
          <%= button_to "delete", app_player_path(p), method: :delete, class: "btn btn-error",
                form: { data: { turbo_confirm: "Delete #{p.name}?" } } %>
        <% end %>
      </div>
      <div class="justify-self-center flex items-center gap-3">
        <%= button_to "-", app_adjust_tickets_path(p), method: :patch, params: { amount: -1 }, class: "btn" %>
        <%= button_to "+", app_adjust_tickets_path(p), method: :patch, params: { amount: 1 }, class: "btn" %>
      </div>
      <div class="justify-self-end">
        <% if p.id == @host.owner_id %>
          <span class="text-sm opacity-60">owner</span>
        <% elsif p.admin? %>
          <%= button_to "demote", app_demote_path(p), method: :patch, class: "btn btn-outline",
                form: { data: { turbo_confirm: "Demote #{p.name} from admin?" } } %>
        <% else %>
          <%= button_to "promote", app_promote_path(p), method: :patch, class: "btn btn-outline",
                form: { data: { turbo_confirm: "Promote #{p.name} to admin? They will be able to edit player names and ticket counts, promote/demote (except #{@host.owner&.name}), and delete non-admins." } } %>
        <% end %>
      </div>
    </div>
  </section>

  <%# Edit the focused player's name; "Done" saves and returns to the table. %>
  <section class="mt-8">
    <%= form_with url: app_player_path(p), method: :patch, scope: :player,
          class: "flex flex-wrap items-center gap-3" do |f| %>
      <%= f.text_field :name, value: p.name, autocomplete: "off",
            autofocus: true, maxlength: 12, class: "input input-bordered" %>
      <%= f.submit "Done", class: "btn btn-primary" %>
    <% end %>
  </section>

<% elsif gifting %>
  <%# ---- Give tickets to one recipient ------------------------------------ %>
  <% r = gift_recipient %>
  <section class="mt-2 mb-6">
    <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
      <% @host.roster.each do |player| %>
        <% focus = player.id == r.id %>
        <%= render "card", player: player,
              classes: (focus ? "bg-secondary text-secondary-content shadow-md" : "bg-base-100 shadow-md"),
              tickets_display: player.tickets, badge: (focus ? "recipient" : nil),
              mine: (player.id == current_player&.id) %>
      <% end %>
    </div>
  </section>

  <section class="text-center">
    <p class="text-2xl mb-4">Give tickets to <%= r.name %></p>
    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
      <div></div>
      <div class="justify-self-center flex items-center gap-3">
        <% if @host.can_undo_latest?(current_player) && @host.latest_log&.action == "gift" %>
          <%= button_to "-", app_ungift_path(r), method: :patch, class: "btn" %>
        <% else %>
          <button type="button" class="btn btn-disabled" disabled>-</button>
        <% end %>
        <% if current_player.tickets.positive? %>
          <%= button_to "+", app_gift_path(r), method: :patch, class: "btn" %>
        <% else %>
          <button type="button" class="btn btn-disabled" disabled>+</button>
        <% end %>
      </div>
      <div class="justify-self-end">
        <%= link_to "done", app_root_path, class: "btn" %>
      </div>
    </div>
    <p class="mt-3 text-sm opacity-70">You have <%= current_player.tickets %> tix to give.</p>
  </section>

<% else %>
  <%# ---- The table: client-side raffle ------------------------------------ %>
  <div data-controller="table"
       data-table-nominate-url-value="<%= app_nominate_path %>"
       data-table-send-url-value="<%= app_send_off_path %>"
       data-table-base-value="<%= app_root_path %>"
       data-table-my-id-value="<%= current_player&.id %>"
       data-table-admin-value="<%= current_admin? %>">

    <section class="mt-2 mb-6">
      <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
        <% @host.roster.each do |player| %>
          <button type="button" class="block w-full p-0 bg-transparent border-0 cursor-pointer select-none"
                  data-table-target="card" data-action="click->table#tapCard"
                  data-player-id="<%= player.id %>" data-tickets="<%= player.tickets %>"
                  data-name="<%= player.name %>" data-owner="<%= player.id == @host.owner_id %>">
            <div class="card h-full transition-shadow bg-base-100 shadow-md">
              <div class="card-body items-center text-center p-1.5 gap-0.5">
                <span class="badge badge-xs invisible">·</span>
                <span class="text-xs <%= player.id == current_player&.id ? "italic font-bold" : "font-semibold" %> <%= "underline" if player.admin? %> leading-tight break-words"><%= player.name %></span>
                <span class="text-[0.65rem] opacity-70 js-tickets"><%= player.tickets %></span>
              </div>
            </div>
          </button>
        <% end %>
      </div>
    </section>

    <section class="text-center">
      <%# Selecting: who is playing the chosen one's game? %>
      <div data-table-target="selectArea" class="hidden">
        <p class="text-2xl mb-4">Who is playing with <span data-table-target="nomineeName"></span>?</p>
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
          <div class="justify-self-start">
            <button type="button" class="btn btn-sm btn-ghost" data-action="table#undoPick">Undo pick</button>
          </div>
          <div class="justify-self-center flex items-center gap-3">
            <button type="button" class="btn btn-ghost border border-base-content/30" data-action="table#selectAll">Select all</button>
            <button type="button" class="btn btn-accent" data-action="table#send">Send</button>
          </div>
          <div></div>
        </div>
      </div>

      <%# Idle: pick / edit / gift. %>
      <div data-table-target="idleArea">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
          <div class="justify-self-start"></div>
          <div class="justify-self-center">
            <span data-table-target="pickArea" class="hidden">
              <button type="button" class="btn btn-primary btn-lg" data-action="table#pick">Pick</button>
            </span>
            <span data-table-target="editArea" class="hidden">
              <a data-table-target="editLink" href="#" class="btn btn-outline btn-neutral">edit</a>
            </span>
            <span data-table-target="giftArea" class="hidden">
              <a data-table-target="giftLink" href="#" class="btn btn-primary btn-lg">Gift</a>
            </span>
          </div>
          <div class="justify-self-end">
            <span data-table-target="shareArea" class="hidden">
              <button type="button" class="btn btn-outline btn-neutral" data-action="table#share">share</button>
            </span>
          </div>
        </div>
      </div>
    </section>

    <%# Hidden share popups, one per shareable player; the share button opens the
        one for the single present player (see table_controller#share). %>
    <% if current_admin? %>
      <% @host.roster.each do |player| %>
        <% next unless can_share.call(player) %>
        <% link = player_url(player.uuid) %>
        <dialog id="share-modal-<%= player.id %>" class="modal">
          <div class="modal-box text-center">
            <h3 class="text-lg font-bold mb-3"><%= player.name %>'s link</h3>
            <div class="mx-auto w-56 bg-white p-3 rounded"><%= qr_svg(link) %></div>
            <p class="mt-3 text-sm break-all"><%= link_to link, link, target: "_blank", rel: "noopener", class: "link link-primary" %></p>
            <% if player.admin? && player.id == current_player&.id %>
              <p class="mt-2 text-sm text-warning">Anyone with this link can take actions in your name.  If you want to share admin privileges with another person, click their player button and promote them to admin, then share their link.</p>
            <% elsif player.admin? %>
              <p class="mt-2 text-sm text-warning">Anyone with this link can act as <%= player.name %>, taking any admin-level action.  Logs will show their actions under <%= player.name %>'s name.  Demote <%= player.name %> to revoke admin access.</p>
            <% else %>
              <p class="mt-2 text-sm text-base-content/70">Anyone with this link can add players, pick pickers, mark them as playing, and gift <%= player.name %>'s tickets.  Logs will show their actions under <%= player.name %>'s name.  Delete <%= player.name %> to revoke access.</p>
            <% end %>
            <div class="modal-action justify-center"><form method="dialog"><button class="btn">Close</button></form></div>
          </div>
          <form method="dialog" class="modal-backdrop"><button aria-label="Close">close</button></form>
        </dialog>
      <% end %>
    <% end %>
  </div>
<% end %>

<% unless host_view? %>
  <%# ---- Add a player (hidden in edit mode, which shows the rename form) --- %>
  <% unless editing_player %>
    <section class="mt-8">
      <%= form_with url: app_players_path, scope: :player, class: "flex flex-wrap items-center gap-3" do |f| %>
        <%= f.text_field :name, placeholder: "Someone's name", autocomplete: "off",
              autofocus: params[:added].present?, maxlength: 12, class: "input input-bordered" %>
        <%= f.submit "+", class: "btn btn-secondary" %>
      <% end %>
    </section>
  <% end %>

  <section class="mt-10 text-center">
    <%= link_to "Show log", app_logs_path, class: "btn btn-ghost btn-sm" %>
  </section>
<% end %>
