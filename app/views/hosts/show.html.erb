<% content_for :title, "Someone Pick" %>
<%
  selecting   = @host.selecting?
  editing     = host_view? && params[:editing].present?
  nominee     = @host.nominated_player
  can_undo    = @host.can_undo_latest?(current_player)

  # The single present player whose card/controls are being edited (host only).
  editing_player = (editing && @host.present_players.count == 1) ? @host.present_players.first : nil

  # Gifting: a player gives tickets to the single present player (the recipient).
  # Never a gift to oneself, so the recipient must differ from the acting player.
  single_present = @host.present_players.count == 1 ? @host.present_players.first : nil
  gifting   = !host_view? && params[:gifting].present? && single_present && single_present.id != current_player&.id
  recipient = gifting ? single_present : nil

  # The "Pick" state: 2+ present players and no special mode. The Pick button
  # plays a suspense animation cycling the present cards before nominating.
  picking = !selecting && @host.present_players.count >= 2

  # The selection controller wraps the grid + buttons only while selecting, so a
  # client-side "who's playing" choice can update the grid and the Send form.
  # The nominate controller wraps the grid + Pick button so the animation can
  # cycle the present cards before the request is actually submitted.
  wrapper =
    if selecting
      { data: { controller: "selection", selection_base_tickets_value: nominee.tickets } }
    elsif picking
      { data: { controller: "nominate" } }
    else
      {}
    end
%>

<h1 class="text-4xl font-bold text-center mb-6">Someone Pick</h1>

<div <%= tag.attributes(wrapper) if wrapper.any? %>>

  <%# ---- One grid, all players (at the top) ------------------------------- %>
  <section class="mt-2 mb-6">
    <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
      <% @host.roster.each do |player| %>
        <%
          is_nominee = selecting && player.id == nominee.id
          is_editing = editing_player && player.id == editing_player.id
          is_recipient = recipient && player.id == recipient.id
          in_room    = player.present?
          selectable = selecting && in_room && !is_nominee
          mine       = !host_view? && current_player&.id == player.id

          classes =
            if is_nominee then "bg-accent text-accent-content ring-2 ring-accent shadow-lg"
            elsif is_editing || is_recipient then "bg-secondary text-secondary-content shadow-md"
            elsif in_room then "bg-primary text-primary-content shadow-md"
            else "bg-base-100 shadow-md"
            end

          # While editing or receiving a gift, show the player's true count (before
          # the +1 they earned for being present).
          tickets_display =
            if is_nominee then @host.nominee_remaining_tickets(0)
            elsif is_editing || is_recipient then [ player.tickets - 1, 0 ].max
            else player.tickets
            end
          badge =
            if is_nominee then "picker"
            elsif is_editing then "editing"
            elsif is_recipient then "recipient"
            elsif in_room then "present"
            end
        %>

        <% if selectable %>
          <%# Pure client-side toggle — no network call. %>
          <%= render "card", player: player,
                classes: "#{classes} cursor-pointer select-none",
                tickets_display: tickets_display, badge: badge, mine: mine,
                card_data: { selection_target: "player", player_id: player.id, action: "click->selection#toggle" } %>
        <% elsif is_nominee || is_editing || is_recipient %>
          <%= render "card", player: player, classes: classes,
                tickets_display: tickets_display, badge: badge, ticket_target: is_nominee, mine: mine %>
        <% else %>
          <% cand = (picking && in_room) ? { nominate_target: "candidate" } : {} %>
          <%= button_to app_toggle_room_path(player), method: :patch,
                class: "block w-full p-0 bg-transparent border-0" do %>
            <%= render "card", player: player, classes: classes,
                  tickets_display: tickets_display, badge: badge, mine: mine, card_data: cand %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# ---- Round actions (below the grid) ----------------------------------- %>
  <section class="text-center">
    <% if selecting %>
      <p class="text-2xl mb-4">Who is playing with <%= nominee.name %>?</p>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <% if can_undo %>
            <%= button_to "Undo pick", app_undo_path, method: :post, class: "btn btn-sm btn-ghost" %>
          <% end %>
        </div>
        <div class="justify-self-center flex items-center gap-3">
          <button type="button" class="btn btn-ghost border border-base-content/30" data-action="selection#selectAll">Select all</button>
          <%= form_with url: app_send_off_path, method: :post do %>
            <span data-selection-target="memberInputs"></span>
            <%= submit_tag "Send", class: "btn btn-accent" %>
          <% end %>
        </div>
        <div></div>
      </div>

    <% elsif editing && @host.present_players.count == 1 %>
      <%# Host edit controls for the single present player. %>
      <% p = @host.present_players.first %>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <%= button_to "delete", host_player_path(@host, p), method: :delete,
                class: "btn btn-error", form: { data: { turbo_confirm: "Delete #{p.name}?" } } %>
        </div>
        <div class="justify-self-center flex items-center gap-3">
          <%= button_to "-", adjust_tickets_host_player_path(@host, p, amount: -1), method: :patch, class: "btn" %>
          <%= button_to "+", adjust_tickets_host_player_path(@host, p, amount: 1), method: :patch, class: "btn" %>
        </div>
        <div></div>
      </div>

    <% elsif gifting %>
      <%# A player giving their tickets to the recipient. + gives one (from the
          giver's supply); - undoes the last gift while it's the latest log entry. %>
      <p class="text-2xl mb-4">Give tickets to <%= recipient.name %></p>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div></div>
        <div class="justify-self-center flex items-center gap-3">
          <% if can_undo && @host.latest_log&.action == "gift" %>
            <%= button_to "-", app_ungift_path(recipient), method: :patch, class: "btn" %>
          <% else %>
            <button type="button" class="btn btn-disabled" disabled>-</button>
          <% end %>
          <% if current_player.tickets.positive? %>
            <%= button_to "+", app_gift_path(recipient), method: :patch, class: "btn" %>
          <% else %>
            <button type="button" class="btn btn-disabled" disabled>+</button>
          <% end %>
        </div>
        <div class="justify-self-end">
          <%# Done removes the recipient from the room, giving back the ticket they
              earned for being present so only the gifts remain. %>
          <%= button_to "done", app_toggle_room_path(recipient), method: :patch, class: "btn" %>
        </div>
      </div>
      <p class="mt-3 text-sm opacity-70">You have <%= current_player.tickets %> tix to give.</p>

    <% else %>
      <% present_count = @host.present_players.count %>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <% if @host.undoable_send_off? && can_undo %>
            <%= button_to "Undo send", app_undo_path, method: :post, class: "btn btn-ghost" %>
          <% end %>
        </div>
        <div class="justify-self-center">
          <% if present_count >= 2 %>
            <%= button_to "Pick", app_nominate_path, method: :post, class: "btn btn-primary btn-lg",
                  form: { data: { action: "submit->nominate#run" } } %>
          <% elsif host_view? && present_count == 1 %>
            <%= link_to "edit", host_path(@host, editing: 1), class: "btn btn-outline btn-neutral" %>
          <% elsif !host_view? && present_count == 1 && single_present && single_present.id != current_player&.id %>
            <%# Exactly one other player present: gift to them instead of nominating. %>
            <%= link_to "Gift", app_root_path(gifting: 1), class: "btn btn-primary btn-lg" %>
          <% end %>
        </div>
        <div class="justify-self-end">
          <% if host_view? && present_count == 1 %>
            <label for="share_modal" class="btn btn-outline btn-neutral">share</label>
          <% end %>
        </div>
      </div>

      <% if host_view? && present_count == 1 %>
        <% p = @host.present_players.first %>
        <% link = player_url(p.uuid) %>
        <input type="checkbox" id="share_modal" class="modal-toggle" />
        <div class="modal" role="dialog">
          <div class="modal-box text-center">
            <h3 class="text-lg font-bold mb-3"><%= p.name %>'s link</h3>
            <div class="mx-auto w-56 bg-white p-3 rounded"><%= qr_svg(link) %></div>
            <p class="mt-3 text-sm break-all"><%= link %></p>
            <p class="mt-2 text-sm text-base-content/70">Anyone with this link can add players, pick pickers, mark them as playing, and gift <%= p.name %>'s tickets.  Logs will show their actions under <%= p.name %>'s name.  Delete <%= p.name %> to revoke access.</p>
            <div class="modal-action justify-center">
              <label for="share_modal" class="btn">Close</label>
            </div>
          </div>
          <label class="modal-backdrop" for="share_modal">Close</label>
        </div>
      <% end %>
    <% end %>
  </section>
</div>

<%# ---- Add / edit player -------------------------------------------------- %>
<section class="mt-8">
  <% if editing_player %>
    <%# Editing: the input holds the player's current name; "Done" (where "Add"
        sits) saves it and then leaves the room (giving back the present ticket). %>
    <%= form_with url: host_player_path(@host, editing_player), method: :patch,
          scope: :player, class: "flex flex-wrap items-center gap-3" do |f| %>
      <%= f.text_field :name, value: editing_player.name, autocomplete: "off",
            autofocus: true, maxlength: 12, class: "input input-bordered" %>
      <%= f.submit "Done", class: "btn btn-primary" %>
    <% end %>
  <% else %>
    <%= form_with url: app_players_path, scope: :player, class: "flex flex-wrap items-center gap-3" do |f| %>
      <%= f.text_field :name, placeholder: "Someone's name", autocomplete: "off",
            autofocus: params[:added].present?, maxlength: 12, class: "input input-bordered" %>
      <%= f.submit "Add", class: "btn btn-secondary" %>
    <% end %>
  <% end %>
</section>

<%# ---- Log ---------------------------------------------------------------- %>
<section class="mt-10 text-center">
  <%= link_to "Show log", app_logs_path, class: "btn btn-ghost btn-sm" %>
</section>
