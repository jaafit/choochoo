<% content_for :title, "Someone Pick" %>
<%
  selecting   = @host.selecting?
  editing     = host_view? && params[:editing].present?
  nominee     = @host.nominated_player
  can_undo    = @host.can_undo_latest?(current_player)

  # The selection controller wraps the grid + buttons only while selecting, so a
  # client-side "who's playing" choice can update the grid and the Send form.
  wrapper = selecting ? { data: {
    controller: "selection",
    selection_base_tickets_value: nominee.tickets
  } } : {}
%>

<h1 class="text-4xl font-bold text-center mb-6">Someone Pick</h1>

<div <%= tag.attributes(wrapper) if wrapper.any? %>>

  <%# ---- One grid, all players (at the top) ------------------------------- %>
  <section class="mt-2 mb-6">
    <div class="grid grid-cols-4 gap-1.5 sm:gap-3">
      <% @host.roster.each do |player| %>
        <%
          is_nominee = selecting && player.id == nominee.id
          in_room    = player.present?
          selectable = selecting && in_room && !is_nominee
          mine       = !host_view? && current_player&.id == player.id

          classes =
            if is_nominee then "bg-accent text-accent-content ring-2 ring-accent shadow-lg"
            elsif in_room then "bg-primary text-primary-content shadow-md"
            else "bg-base-100 shadow-md"
            end

          tickets_display = is_nominee ? @host.nominee_remaining_tickets(0) : player.tickets
          badge =
            if is_nominee then "picker"
            elsif in_room then "present"
            end
        %>

        <% if selectable %>
          <%# Pure client-side toggle — no network call. %>
          <%= render "card", player: player,
                classes: "#{classes} cursor-pointer select-none",
                tickets_display: tickets_display, badge: badge, mine: mine,
                card_data: { selection_target: "player", player_id: player.id, action: "click->selection#toggle" } %>
        <% elsif is_nominee %>
          <%= render "card", player: player, classes: classes,
                tickets_display: tickets_display, badge: badge, ticket_target: true, mine: mine %>
        <% else %>
          <%= button_to app_toggle_room_path(player), method: :patch,
                class: "block w-full p-0 bg-transparent border-0" do %>
            <%= render "card", player: player, classes: classes,
                  tickets_display: tickets_display, badge: badge, mine: mine %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# ---- Round actions (below the grid) ----------------------------------- %>
  <section class="text-center">
    <% if selecting %>
      <p class="text-2xl mb-4">Who is playing with <%= nominee.name %>?</p>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <% if can_undo %>
            <%= button_to "Undo nominate", app_undo_path, method: :post, class: "btn btn-sm btn-ghost" %>
          <% end %>
        </div>
        <div class="justify-self-center flex items-center gap-3">
          <button type="button" class="btn btn-ghost border border-base-content/30" data-action="selection#selectAll">Select all</button>
          <%= form_with url: app_send_off_path, method: :post do %>
            <span data-selection-target="memberInputs"></span>
            <%= submit_tag "Send", class: "btn btn-accent" %>
          <% end %>
        </div>
        <div></div>
      </div>

    <% elsif editing && @host.present_players.count == 1 %>
      <%# Host edit controls for the single present player. %>
      <% p = @host.present_players.first %>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <%= button_to "delete", host_player_path(@host, p), method: :delete,
                class: "btn btn-error", form: { data: { turbo_confirm: "Delete #{p.name}?" } } %>
        </div>
        <div class="justify-self-center flex items-center gap-3">
          <%= button_to "add", adjust_tickets_host_player_path(@host, p, amount: 1), method: :patch, class: "btn" %>
          <%= button_to "subtract", adjust_tickets_host_player_path(@host, p, amount: -1), method: :patch, class: "btn" %>
        </div>
        <div class="justify-self-end">
          <%= link_to "done", host_path(@host), class: "btn" %>
        </div>
      </div>

    <% else %>
      <% present_count = @host.present_players.count %>
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
        <div class="justify-self-start">
          <% if @host.undoable_send_off? && can_undo %>
            <%= button_to "Undo send", app_undo_path, method: :post, class: "btn btn-ghost" %>
          <% end %>
        </div>
        <div class="justify-self-center">
          <% if host_view? && present_count == 1 %>
            <%= link_to "edit", host_path(@host, editing: 1), class: "btn btn-outline btn-neutral" %>
          <% elsif host_view? && present_count >= 2 %>
            <%= button_to "Nominate", app_nominate_path, method: :post, class: "btn btn-primary btn-lg" %>
          <% elsif !host_view? && present_count >= 1 %>
            <%= button_to "Nominate", app_nominate_path, method: :post, class: "btn btn-primary btn-lg" %>
          <% end %>
        </div>
        <div class="justify-self-end">
          <% if host_view? && present_count == 1 %>
            <label for="share_modal" class="btn btn-outline btn-neutral">share</label>
          <% end %>
        </div>
      </div>

      <% if host_view? && present_count == 1 %>
        <% p = @host.present_players.first %>
        <% link = player_url(p.uuid) %>
        <input type="checkbox" id="share_modal" class="modal-toggle" />
        <div class="modal" role="dialog">
          <div class="modal-box text-center">
            <h3 class="text-lg font-bold mb-3"><%= p.name %>'s link</h3>
            <div class="mx-auto w-56 bg-white p-3 rounded"><%= qr_svg(link) %></div>
            <p class="mt-3 text-sm break-all"><%= link %></p>
            <div class="modal-action justify-center">
              <label for="share_modal" class="btn">Close</label>
            </div>
          </div>
          <label class="modal-backdrop" for="share_modal">Close</label>
        </div>
      <% end %>
    <% end %>
  </section>
</div>

<%# ---- Add player --------------------------------------------------------- %>
<section class="mt-8">
  <%= form_with url: app_players_path, scope: :player, class: "flex flex-wrap items-center gap-3" do |f| %>
    <%= f.text_field :name, placeholder: "New Player", autocomplete: "off",
          autofocus: params[:added].present?, maxlength: 12, class: "input input-bordered" %>
    <%= f.submit "Add Player", class: "btn btn-secondary" %>
  <% end %>
</section>

<%# ---- Log ---------------------------------------------------------------- %>
<section class="mt-10 text-center">
  <%= link_to "Show log", app_logs_path, class: "btn btn-ghost btn-sm" %>
</section>
