<%# Compact player card for the grid (claim / editing / gifting views).
    locals: player, classes, tickets_display, badge (label or nil)
    optional: card_data (hash of data-* attrs), mine (bool) %>
<% card_data = local_assigns.fetch(:card_data, {}) %>
<% mine = local_assigns.fetch(:mine, false) %>
<div class="card <%= classes %> h-full transition-shadow" <%= tag.attributes(data: card_data) if card_data.any? %>>
  <div class="card-body items-center text-center p-1.5 gap-0.5">
    <%# Always render the badge line (invisible when empty) so card height is
        constant — toggling a player on/off never shifts the grid. %>
    <span class="badge badge-xs <%= badge ? "badge-neutral" : "invisible" %>"><%= badge || "·" %></span>
    <%# Admins' names are underlined wherever a player card appears. %>
    <span class="text-xs <%= mine ? "italic font-bold" : "font-semibold" %> <%= "underline" if player.admin? %> leading-tight break-words"><%= player.name %></span>
    <span class="text-[0.65rem] opacity-70"><%= tickets_display %></span>
  </div>
</div>
